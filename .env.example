# Copy to .env and fill in your values

# PostgreSQL
POSTGRES_DB=todo_prod
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=change-me

# API
DATABASE_URL=postgresql://todo_user:change-me@postgres:5432/todo_prod
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Docker image registry settings (for CD)
REGISTRY=ghcr.io
IMAGE_OWNER=your-github-username
TAG=latest

# Web
WEB_PORT=80
CORS_ORIGIN=http://your-nas-hostname
