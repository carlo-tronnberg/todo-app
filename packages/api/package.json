    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.9",
    "@vitest/coverage-v8": "^1.6.0",
    "drizzle-kit": "^0.22.7",
